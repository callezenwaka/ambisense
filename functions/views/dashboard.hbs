<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="description" content="Learn how to use the Firebase platform on the Web">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Ambisense</title>

        <!-- Disable tap highlight on IE -->
        <meta name="msapplication-tap-highlight" content="no">

        <!-- Web Application Manifest -->
        <link rel="manifest" href="/ambisense/manifest.json">
        
        <!-- Favicont -->
        <link rel="shortcut icon" href="/ambisense/favicon.ico" type="image/x-icon">

        <!-- Add to homescreen for Chrome on Android -->
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="application-name" content="Ambisense">
        <meta name="theme-color" content="#303F9F">

        <!-- Add to homescreen for Safari on iOS -->
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <meta name="apple-mobile-web-app-title" content="Ambisense">
        <meta name="apple-mobile-web-app-status-bar-style" content="#303F9F">

        <!-- Tile icon for Win8 -->
        <meta name="msapplication-TileColor" content="#3372DF">
        <meta name="msapplication-navbutton-color" content="#303F9F">

        <!-- App Styling -->
        <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto:regular,bold,italic,thin,light,bolditalic,black,medium&amp;lang=en">
        <style>
            h1 {
                width: 60%;
                margin: 20% auto;
                text-align: center;
                font-family: fantasy;
            }
            .home, form {
                width: 60%;
                margin: 3rem auto;
                text-align: center;
                font-family: fantasy;
            }
        </style>
    </head>
    <body>
        <div>
            <h1>{{heading}}</h1>
            <div class="home">
                <a href="/ambisense/" rel="noopener noreferrer">Home</a>
            </div>
            <form action="/ambisense/sensor/12345678" method="post">
                <label for="temp">Temperature:</label><br>
                <input type="text" name="temperature" id="temperature"><br>
                <label for="hum">Humidity:</label><br>
                <input type="text" name="humidity" id="humidity">
                <br><br>
                <button type="submit">Submit</button>
            </form>
        </div>
        <!-- Import and configure the Firebase SDK -->
        <!-- These scripts are made available when the app is served or deployed on Firebase Hosting -->
        <!-- If you do not want to serve/host your project using Firebase Hosting see https://firebase.google.com/docs/web/setup -->
